<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsAotCompatible>true</IsAotCompatible>
    <IsTrimmable>true</IsTrimmable>
    <IsPackable>true</IsPackable>
    <PackageId>PicoYaml</PackageId>
    <Description>PicoYaml — high-performance, AOT-first YAML serializer with zero-reflection source generation for the PicoHex ecosystem</Description>
    <PackageTags>PicoHex;YAML;AOT;Serialization</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\..\..\README.md" Pack="true" PackagePath="" Visible="false" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\PicoSerDe.Core\src\PicoSerDe.Core.csproj" />
    <ProjectReference
      Include="..\PicoYaml.Gen\PicoYaml.Gen.csproj"
      OutputItemType="Analyzer"
      ReferenceOutputAssembly="false"
    />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="PicoYaml.Tests" />
  </ItemGroup>

  <!-- Embed the PicoYaml.Gen source generator DLL in the consumer NuGet package -->
  <ItemGroup Condition="'$(IsPackable)' == 'true'">
    <None
      Include="..\PicoYaml.Gen\bin\$(Configuration)\netstandard2.0\PicoYaml.Gen.dll"
      Pack="true"
      PackagePath="analyzers/dotnet/cs/"
      Visible="false"
    />
  </ItemGroup>
  <!-- Fail fast if the SG DLL is missing (e.g., out-of-order build) -->
  <Target Name="EnsurePicoYamlGenDllExists" BeforeTargets="GenerateNuspec" Condition="'$(IsPackable)' == 'true'">
    <Warning Text="PicoYaml.Gen.dll not found at expected path. Run build on PicoYaml.Gen first."
             Condition="!Exists('..\PicoYaml.Gen\bin\$(Configuration)\netstandard2.0\PicoYaml.Gen.dll')" />
  </Target>
  <ItemGroup>
    <PackageReference Update="Microsoft.SourceLink.GitHub" Version="10.0.300" />
  </ItemGroup>
</Project>
