<Project Sdk="Microsoft.NET.Sdk" TreatAsLocalProperty="PublishAot">
    <PropertyGroup>
        <TargetFramework>netstandard2.0</TargetFramework><PublishAot>false</PublishAot>
        <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
        <IsRoslynComponent>true</IsRoslynComponent>
        <LangVersion>latest</LangVersion><Nullable>enable</Nullable><ImplicitUsings>disable</ImplicitUsings>
        <NoWarn>$(NoWarn);RS2008;RS1041;NU5128</NoWarn>
        <IsPackable>false</IsPackable>
    </PropertyGroup>
    <ItemGroup><None Include="$(OutputPath)/$(AssemblyName).dll" Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" /></ItemGroup>
    <ItemGroup><PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.*" PrivateAssets="all" /></ItemGroup>
</Project>
