<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <PublishAot>false</PublishAot>
        <TrimMode>partial</TrimMode>
        <LangVersion>latest</LangVersion><Nullable>enable</Nullable><ImplicitUsings>enable</ImplicitUsings>
        <IsPackable>false</IsPackable>
    </PropertyGroup>
    <ItemGroup>
        <PackageReference Include="PicoBench" Version="*" />
        <PackageReference Include="VYaml" Version="1.*" />
        <PackageReference Include="VYaml.Annotations" Version="1.*" />
    </ItemGroup>
    <ItemGroup>
        <Compile Include="..\..\..\shared\BenchModels.cs" Link="BenchModels.cs" />
    </ItemGroup>
    <ItemGroup>
        <ProjectReference Include="..\..\src\PicoYaml\PicoYaml.csproj" />
        <ProjectReference Include="..\..\src\PicoYaml.Gen\PicoYaml.Gen.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
    </ItemGroup>
</Project>
