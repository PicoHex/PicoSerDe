    <ItemGroup>
        <ProjectReference Include="..\..\src\PicoMsgPack\PicoMsgPack.csproj" />
        <ProjectReference Include="..\..\src\PicoMsgPack.Gen\PicoMsgPack.Gen.csproj"
                          OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
    </ItemGroup>

</Project>
